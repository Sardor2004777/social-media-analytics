# ==============================================================================
# Django core
# ==============================================================================
# Long random string. Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
# Comma-separated. In prod: your-domain.com,www.your-domain.com
ALLOWED_HOSTS=localhost,127.0.0.1
# Which settings module: config.settings.dev | config.settings.prod | config.settings.test
DJANGO_SETTINGS_MODULE=config.settings.dev

# ==============================================================================
# Database
# ==============================================================================
# Dev: sqlite:///db.sqlite3 (default). Prod: postgres://user:pass@host:5432/db
DATABASE_URL=sqlite:///db.sqlite3

# ==============================================================================
# Cache / Celery broker
# ==============================================================================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ==============================================================================
# Email (dev uses console backend by default; set for prod SMTP/SendGrid)
# ==============================================================================
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your-sendgrid-api-key
DEFAULT_FROM_EMAIL=noreply@example.com

# ==============================================================================
# Token encryption (for SocialAccount.access_token at rest)
# ==============================================================================
# 32+ bytes base64. Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-fernet-key

# ==============================================================================
# Google OAuth (user login via allauth)
# ==============================================================================
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_SECRET=

# ==============================================================================
# Instagram (Meta Graph API) — Business/Creator account required
# ==============================================================================
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:8000/social/callback/instagram/

# ==============================================================================
# Telegram (Bot API — legacy fallback)
# ==============================================================================
# Created via @BotFather. User pastes their own token in UI per-account;
# this one is the platform-level fallback bot if any.
TELEGRAM_BOT_TOKEN=

# ==============================================================================
# Telegram (MTProto / Telethon — real-mode collector for PUBLIC channels)
# ==============================================================================
# 1. Get API_ID + API_HASH at https://my.telegram.org/apps (log in with your phone).
# 2. Generate a session string once:
#        python manage.py telegram_generate_session
#    Paste the printed string below. The session is equivalent to being logged in
#    as your Telegram account — treat it like a password, never commit it.
# 3. Leave all three blank to keep Telegram in demo-only mode.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=

# ==============================================================================
# YouTube Data API v3
# ==============================================================================
YOUTUBE_API_KEY=
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_SECRET=

# ==============================================================================
# X (Twitter) API v2
# ==============================================================================
X_CLIENT_ID=
X_CLIENT_SECRET=

# ==============================================================================
# Sentiment analysis
# ==============================================================================
# local | api. "local" uses transformers+torch; "api" uses HuggingFace Inference API.
SENTIMENT_BACKEND=local
HF_API_TOKEN=
SENTIMENT_MODEL=cardiffnlp/twitter-xlm-roberta-base-sentiment

# ==============================================================================
# Observability (prod)
# ==============================================================================
SENTRY_DSN=

# ==============================================================================
# Rate limiting / collector schedule
# ==============================================================================
COLLECT_INTERVAL_HOURS=6
API_THROTTLE_USER=1000/day
API_THROTTLE_ANON=100/day
